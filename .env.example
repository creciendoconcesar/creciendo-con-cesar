# Copia este archivo como .env.local y completa los valores reales.
# Ninguna de estas variables es obligatoria para correr el sitio en local:
# sin ellas, el sitio funciona pero las integraciones quedan inactivas
# (las notificaciones se imprimen en la consola del servidor).

# --- Notificaciones (formulario de aplicación y masterclass) ---
# Cuenta en https://resend.com — plan gratuito alcanza para empezar.
RESEND_API_KEY=
NOTIFY_EMAIL_TO=cesar@tudominio.com
NOTIFY_EMAIL_FROM=onboarding@resend.dev

# --- Analítica ---
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=
